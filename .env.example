# Copy this to .env (or .env.local) and fill in as needed. Vite only exposes
# VITE_-prefixed vars to client code (import.meta.env.VITE_*).

# Multiplayer WS server port. The host is derived automatically from the page's
# own hostname (so LAN clients connect back to whichever machine served the page)
# unless VITE_MP_SERVER_URL below is set to override this entirely.
VITE_MP_SERVER_PORT=8787
# VITE_MP_SERVER_URL=ws://localhost:8787

# Same idea for the REST API (session/save-data) — defaults to http://<page-hostname>:8787.
# VITE_API_URL=http://localhost:8787

# --- Production example (client and server on different domains) ---
# VITE_MP_SERVER_URL=wss://coopy-bird-server.fly.dev
# VITE_API_URL=https://coopy-bird-server.fly.dev
