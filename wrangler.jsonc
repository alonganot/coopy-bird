{
  // This project deploys via `wrangler pages deploy` (Cloudflare Pages), which uses
  // `pages_build_output_dir` — the Workers-style `assets.directory` field isn't valid
  // here and fails config validation, hence no `assets` block below.
  "name": "coopy-bird",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-01-01"
}
