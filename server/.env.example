# Copy this to server/.env for local development, then run `npm run server:dev` (loads
# this file automatically via `tsx --env-file`) instead of `npm run server`, which
# doesn't load it and is what Docker/Fly production uses (real env vars injected
# directly there — `docker-compose.yml`'s `environment:` block / `fly secrets set` —
# never bake secrets into the Docker image or this example file).

# Postgres connection string. This default matches docker-compose.yml's bundled
# Postgres service (`docker compose up -d postgres`) — host port 5433, not 5432, to
# avoid clashing with any native Postgres install already using the default port.
DATABASE_URL=postgres://coopybird:coopybird@localhost:5433/coopybird

# Port the HTTP+WS server listens on.
PORT=8787

# CORS origin allowed to call the REST API / connect the WebSocket from a browser.
# Set to your deployed client's origin in production (e.g. https://coopy-bird.pages.dev).
ALLOWED_ORIGIN=*
