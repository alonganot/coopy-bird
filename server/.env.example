# Copy this to server/.env for local development. The `server` npm script doesn't load
# it automatically — either run `npx tsx --env-file=server/.env server/index.ts` directly,
# or export these into your shell before `npm run server`. `docker-compose.yml` sets them
# as real container env vars instead of a file. In production (Fly.io), set them via
# `fly secrets set` — never bake secrets into the Docker image.

# Postgres connection string. Free options: Neon (neon.tech), Supabase, or Fly Postgres.
# Example: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Port the HTTP+WS server listens on.
PORT=8787

# CORS origin allowed to call the REST API / connect the WebSocket from a browser.
# Set to your deployed client's origin in production (e.g. https://coopy-bird.pages.dev).
ALLOWED_ORIGIN=*
